# Vercel ignore file
# Exclude files and directories from deployment

# Development files
.env.local
.env.development
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Documentation
*.md
!README.md
docs/
CHANGELOG.md
LICENSE

# Build tools
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
tmp/
temp/
.tmp/

# Supabase local development
supabase/.temp/
supabase/logs/

# Scripts and deployment files
scripts/
deploy*.mjs
build-and-deploy.mjs
verify-deployment.mjs
*.log

# Extension files (not needed for web deployment)
extension/

# iOS app files (not needed for web deployment)
ios/

# Capacitor build files
android/
capacitor.config.ts

# Database migration files
*.sql
apply-*.js
apply-*.mjs
run_migration.js

# Large dependencies that aren't needed
all-app/