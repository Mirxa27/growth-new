<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Newomen</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Newomen uses the camera to capture images for assessments, profile photos, and visual learning experiences. This helps provide personalized content and enables image-based assessment questions.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Newomen needs access to your photo library to select images for your profile, save assessment results, and enable image-based learning activities.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Newomen uses your location to provide personalized experiences, local content recommendations, and location-based wellness insights while you use the app.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Newomen may use your location to provide personalized experiences and local content recommendations.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Newomen uses the microphone for voice-based assessments, audio responses, and interactive voice features that enhance your learning experience.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Newomen sends notifications to remind you about assessments, share insights, and keep you engaged with your personal growth journey.</string>
	<key>NSFileProviderUsageDescription</key>
	<string>Newomen needs file access to save and sync your assessment results, progress data, and learning materials across devices.</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>Newomen may access your music library for audio-based assessments and personalized content recommendations.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIBackgroundModes</key>
	<array>
		<string>background-processing</string>
		<string>remote-notification</string>
		<string>background-sync</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.newomen.me</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>newomen</string>
				<string>com.newomen.me</string>
			</array>
		</dict>
	</array>
</dict>
</plist>