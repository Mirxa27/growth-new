{
  "name": "newomen-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && vite build",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "preview": "vite preview",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "build:production": "npm run clean && npm run type-check && vite build",
    "build:vercel": "npm run clean && NODE_ENV=production vite build --mode production",
    "deploy": "npm run build:production && npm run preview",
    "deploy:vercel": "vercel --prod",
    "deploy:vercel-fixed": "node deploy-vercel-fixed.mjs",
    "deploy:netlify": "netlify deploy --prod",
    "vercel-build": "npm run build:vercel",
    "postbuild": "echo 'Build completed successfully'",
    "setup-env": "node scripts/setup-vercel-env.js",
    "check-config": "node scripts/setup-vercel-env.js",
    "pre-deploy-check": "node scripts/pre-deployment-check.js",
    "seed-assessments": "node scripts/seed-assessments.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
