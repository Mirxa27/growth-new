# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration
VITE_OPENAI_API_KEY=sk-proj-your-openai-api-key
VITE_OPENAI_ORGANIZATION_ID=org-your-org-id
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_MAX_TOKENS=2000
VITE_OPENAI_TEMPERATURE=0.7

# Application Configuration
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Life Navigation System
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_VOICE_CHAT=true
VITE_ENABLE_AI_ASSESSMENT=true
VITE_ENABLE_COMMUNITY=true

# Security
VITE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
VITE_ENCRYPTION_KEY=your-encryption-key-at-least-32-characters
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
VITE_CSRF_PROTECTION=true

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=900000

# Logging
VITE_LOG_LEVEL=info
VITE_DEBUG_MODE=true

# Analytics (Optional)
VITE_GA_TRACKING_ID=
VITE_MIXPANEL_TOKEN=