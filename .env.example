# Newomen Platform Environment Variables
# Copy this file to .env and fill in your actual values

# ===== REQUIRED VARIABLES =====

# OpenAI Configuration (Required for AI features)
VITE_OPENAI_API_KEY=your-openai-api-key-here
# Get your API key from: https://platform.openai.com/api-keys

# Supabase Configuration (Required for database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Get these from: https://supabase.com/dashboard/project/your-project/settings/api

# ===== OPTIONAL VARIABLES =====

# OpenAI Advanced Configuration
VITE_OPENAI_ORGANIZATION_ID=org-your-organization-id
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_MAX_TOKENS=2000
VITE_OPENAI_TEMPERATURE=0.7

# Feature Flags
VITE_ENABLE_VOICE_CHAT=true
VITE_ENABLE_AI_ASSESSMENT=true
VITE_ENABLE_COMMUNITY=true

# Application Configuration
VITE_APP_NAME=Newomen Platform
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:5173

# Security (Production Only)
VITE_JWT_SECRET=your-32-character-jwt-secret-here
VITE_ENCRYPTION_KEY=your-32-character-encryption-key-here
VITE_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=900000

# Logging & Debug
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=info

# Analytics (Optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# CSRF Protection
VITE_CSRF_PROTECTION=true

# ===== VERCEL DEPLOYMENT NOTES =====
#
# When deploying to Vercel:
# 1. Go to your Vercel Dashboard
# 2. Select your project
# 3. Go to Settings > Environment Variables
# 4. Add each variable above with your actual values
# 5. Make sure to set the environment (Production, Preview, Development)
# 6. Redeploy your application after adding variables
#
# Important: All variables starting with VITE_ will be exposed to the browser
# Never put sensitive server-only keys in VITE_ variables
#
# For server-side variables (like service role keys), use without VITE_ prefix:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here