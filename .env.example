# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration
# For development: Add your API key here
# For production: Use Supabase Edge Functions (leave empty)
VITE_OPENAI_API_KEY=sk-your-openai-api-key
VITE_OPENAI_ORGANIZATION_ID=org-your-org-id
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-10-01
VITE_OPENAI_MAX_TOKENS=2000
VITE_OPENAI_TEMPERATURE=0.7

# API Mode Configuration
# Set to 'true' to force proxy mode even in development
VITE_USE_OPENAI_PROXY=false

# Application Settings
VITE_APP_URL=https://newomen.me
VITE_APP_NAME=NewMe - Life Navigation System
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_VOICE_CHAT=true
VITE_ENABLE_AI_ASSESSMENT=true
VITE_ENABLE_COMMUNITY=true

# Security (for production)
VITE_JWT_SECRET=your-jwt-secret-at-least-32-chars
VITE_ENCRYPTION_KEY=your-encryption-key-at-least-32-chars
VITE_ALLOWED_ORIGINS=https://newomen.me,https://localhost:5173
VITE_CSRF_PROTECTION=true

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=900000

# Debug
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info