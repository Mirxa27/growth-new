# Vercel Environment Variables Template
# Copy this to your Vercel project settings

# Core Application Settings
NODE_ENV=production
VITE_APP_URL=https://your-vercel-domain.vercel.app
VITE_API_URL=https://your-vercel-domain.vercel.app/api

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI Provider Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Voice & Real-time Configuration
VITE_ENABLE_VOICE=true
VITE_VOICE_AGENT_URL=your-voice-agent-url

# Analytics & Monitoring
VITE_ENABLE_ANALYTICS=true
VITE_POSTHOG_KEY=your-posthog-key

# Testing Configuration (optional)
TEST_FUNCTIONS_URL=https://your-test-functions-url

# Security Headers (customized per environment)
VITE_ENABLE_CSP=true
VITE_ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app

# Mobile & Capacitor Configuration
VITE_CAPACITOR_ENABLED=true
VITE_IOS_APP_ID=com.yourcompany.growthecho
VITE_ANDROID_APP_ID=com.yourcompany.growthecho